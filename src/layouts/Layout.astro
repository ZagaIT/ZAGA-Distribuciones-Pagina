---
import '../styles/global.css';
import { Font } from 'astro:assets';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { SITE } from '../config/site';

interface Props {
  lang: string;
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  lang,
  title,
  description = 'ZAGA Distribuciones: suministro e instalación de equipo y material eléctrico en Tampico, Tamaulipas. Cotización rápida y entrega inmediata en todo México.',
  ogImage = SITE.ogImage,
  noindex = false,
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID;

// --- URLs canónicas y alternas por idioma ---
const withSlash = (p: string) => (p.endsWith('/') ? p : p + '/');
const pathname = Astro.url.pathname;
// Ruta equivalente en español (sin prefijo /en)
const esPath = withSlash(pathname.replace(/^\/en(\/|$)/, '/'));
// Ruta equivalente en inglés (con prefijo /en)
const enPath = esPath === '/' ? '/en/' : withSlash(`/en${esPath}`);

const canonicalURL = new URL(withSlash(pathname), Astro.site);
const esURL = new URL(esPath, Astro.site);
const enURL = new URL(enPath, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

const ogLocale = lang === 'en' ? 'en_US' : 'es_MX';
const ogLocaleAlt = lang === 'en' ? 'es_MX' : 'en_US';

// --- Datos estructurados (schema.org) para Google y motores de IA ---
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'LocalBusiness'],
  '@id': `${SITE.url}/#organization`,
  name: SITE.name,
  url: `${SITE.url}/`,
  logo: {
    '@type': 'ImageObject',
    url: `${SITE.url}/logoZaga.png`,
    width: 1024,
    height: 1024,
  },
  image: `${SITE.url}${SITE.ogImage}`,
  description:
    lang === 'en'
      ? 'Supply and installation of electrical equipment and materials. Fast quotes and on-time delivery throughout Mexico.'
      : 'Suministro e instalación de equipo y material eléctrico. Cotizaciones rápidas y entregas a tiempo en todo México.',
  telephone: SITE.phones.primaryPlain,
  email: SITE.emails.primary,
  address: {
    '@type': 'PostalAddress',
    ...(SITE.address.streetAddress && { streetAddress: SITE.address.streetAddress }),
    addressLocality: SITE.address.locality,
    addressRegion: SITE.address.region,
    ...(SITE.address.postalCode && { postalCode: SITE.address.postalCode }),
    addressCountry: SITE.address.countryCode,
  },
  ...(SITE.geo.latitude != null &&
    SITE.geo.longitude != null && {
      geo: {
        '@type': 'GeoCoordinates',
        latitude: SITE.geo.latitude,
        longitude: SITE.geo.longitude,
      },
    }),
  areaServed: { '@type': 'Country', name: 'México' },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: SITE.phones.primaryPlain,
      contactType: 'sales',
      availableLanguage: ['Spanish', 'English'],
    },
    {
      '@type': 'ContactPoint',
      telephone: SITE.phones.secondaryPlain,
      contactType: 'customer service',
      availableLanguage: ['Spanish', 'English'],
    },
  ],
  knowsAbout: [
    'material eléctrico',
    'equipo eléctrico',
    'conductores eléctricos',
    'cable antirrobo CCS',
    'tubería conduit',
    'iluminación industrial',
    'sistemas de puesta a tierra',
    'pararrayos',
    'tableros eléctricos',
    'distribución eléctrica',
  ],
  ...(SITE.socialProfiles.length > 0 && { sameAs: SITE.socialProfiles }),
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE.url}/#website`,
  url: `${SITE.url}/`,
  name: SITE.name,
  inLanguage: lang === 'en' ? 'en-US' : 'es-MX',
  publisher: { '@id': `${SITE.url}/#organization` },
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Aplica el preset guardado antes del primer render (evita parpadeo) -->
    <script is:inline>
      (() => {
        try {
          const p = localStorage.getItem('zaga-preset');
          if (p && ['original', 'neon', 'ambar', 'esmeralda',
                    'voltaje', 'altovoltaje', 'retro', 'taller'].includes(p)) {
            document.documentElement.dataset.preset = p;
          }
        } catch (_) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Alternativas por idioma (hreflang) -->
    <link rel="alternate" hreflang="es" href={esURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={esURL} />

    <!-- SEO geográfico -->
    <meta name="geo.region" content="MX-TAM" />
    <meta name="geo.placename" content={`${SITE.address.locality}, ${SITE.address.region}`} />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Iconos -->
    <link rel="icon" type="image/png" href="/logoZaga.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#1E224F" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fuentes display de los presets tipográficos (auto-hospedadas) -->
    <Font cssVariable="--font-display-industrial" />
    <Font cssVariable="--font-display-retro" />
    <Font cssVariable="--font-display-tech" />
    <Font cssVariable="--font-display-taller" />

    <!-- Datos estructurados schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

    <!-- Google Analytics Condicional -->
    {
      gaId && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} is:inline></script>
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
  </head>
  <body>
    <Navbar />
    <main class="flex-grow flex flex-col">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.animate-on-scroll').forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
