---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Image } from 'astro:assets';
import almacenZaga from '../../assets/almacen.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout lang={lang} title={`ZAGA - ${t('nav.about')}`}>
  <section class="container mx-auto px-6 py-20 lg:py-32 flex-grow overflow-hidden">
    
    <!-- Encabezado Nosotros -->
    <div class="text-center max-w-3xl mx-auto mb-20 animate-on-scroll">
      <h1 class="text-5xl font-extrabold text-zaga-navy mb-6 tracking-tight relative inline-block">
        {t('nav.about')}
        <span class="absolute -bottom-2 left-1/4 right-1/4 h-1.5 bg-zaga-cyan rounded-full"></span>
      </h1>
    </div>

    <!-- Misión, Visión, Valores Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-28 max-w-7xl mx-auto">
      
      <!-- Misión -->
      <div class="bg-white p-10 rounded-3xl shadow-lg border-t-8 border-zaga-blue hover:shadow-2xl transition-all duration-300 animate-on-scroll">
        <h3 class="text-3xl font-bold text-zaga-navy mb-6 flex items-center gap-3">
          <svg class="w-8 h-8 text-zaga-cyan" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
          {t('about.mission.title')}
        </h3>
        <p class="text-gray-600 text-lg leading-relaxed text-justify">
          {t('about.mission.text')}
        </p>
      </div>

      <!-- Visión -->
      <div class="bg-white p-10 rounded-3xl shadow-lg border-t-8 border-zaga-cyan hover:shadow-2xl transition-all duration-300 animate-on-scroll" style="transition-delay: 100ms;">
        <h3 class="text-3xl font-bold text-zaga-navy mb-6 flex items-center gap-3">
          <svg class="w-8 h-8 text-zaga-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
          {t('about.vision.title')}
        </h3>
        <p class="text-gray-600 text-lg leading-relaxed text-justify">
          {t('about.vision.text')}
        </p>
      </div>

      <!-- Valores -->
      <div class="bg-white p-10 rounded-3xl shadow-lg border-t-8 border-gray-900 hover:shadow-2xl transition-all duration-300 animate-on-scroll" style="transition-delay: 200ms;">
        <h3 class="text-3xl font-bold text-zaga-navy mb-6 flex items-center gap-3">
          <svg class="w-8 h-8 text-zaga-cyan" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg>
          {t('about.values.title')}
        </h3>
        <p class="text-gray-600 text-lg leading-relaxed text-justify">
          {t('about.values.text')}
        </p>
      </div>

    </div>

    <!-- Sección Infraestructura / Experiencia -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 md:gap-24 items-center max-w-7xl mx-auto">
      
      <!-- Text / Info Column -->
      <div class="space-y-8 animate-on-scroll">
        <div>
          <h2 class="text-4xl font-extrabold text-zaga-navy mb-6 tracking-tight relative inline-block">
            {t('about.experience.title')}
            <span class="absolute -bottom-2 left-0 right-1/2 h-1 bg-zaga-cyan rounded-full"></span>
          </h2>
          <p class="text-xl text-gray-600 leading-relaxed text-justify md:text-left">
            {t('about.experience.desc')}
          </p>
        </div>

        <!-- Custom List -->
        <ul class="space-y-6 pt-4">
          <li class="flex items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-50 text-zaga-blue flex items-center justify-center mt-0.5 mr-5 shadow-sm">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
            </span>
            <span class="text-gray-800 text-xl font-medium pt-0.5">{t('about.list.one')}</span>
          </li>
          <li class="flex items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-50 text-zaga-blue flex items-center justify-center mt-0.5 mr-5 shadow-sm">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
            </span>
            <span class="text-gray-800 text-xl font-medium pt-0.5">{t('about.list.two')}</span>
          </li>
          <li class="flex items-start">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-50 text-zaga-blue flex items-center justify-center mt-0.5 mr-5 shadow-sm">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
            </span>
            <span class="text-gray-800 text-xl font-medium pt-0.5">{t('about.list.three')}</span>
          </li>
        </ul>
      </div>

      <!-- Image Column -->
      <div class="animate-on-scroll" style="transition-delay: 200ms;">
        <div class="rounded-3xl shadow-2xl relative overflow-hidden group aspect-[4/3] border border-gray-100">
          <Image alt="Almacén de ZAGA Distribuciones" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" src={almacenZaga}/>
          <div class="absolute inset-0 bg-gradient-to-t from-zaga-navy/60 to-transparent pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="absolute bottom-6 left-6 right-6 translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
            <span class="block bg-white/90 backdrop-blur-sm text-zaga-navy font-bold px-4 py-2 rounded shadow text-center text-sm md:text-base">Instalaciones de Primer Nivel</span>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>
