---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout lang={lang} title={t('seo.contact.title')} description={t('seo.contact.desc')}>
  <section class="container mx-auto px-6 py-20 lg:py-32 flex-grow overflow-hidden">
    
    <!-- Encabezado Contacto -->
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
      <h1 class="display-title text-5xl font-extrabold text-zaga-navy mb-6 tracking-tight relative inline-block">
        {t('contact.title')}
        <span class="absolute -bottom-2 left-1/4 right-1/4 h-1 bg-zaga-cyan rounded-full"></span>
      </h1>
      <p class="text-xl text-gray-600 mt-6 max-w-2xl mx-auto">
        {t('contact.subtitle')}
      </p>
    </div>

    <!-- Grid de Tarjetas de Contacto -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto mt-12">
      
      <!-- Tarjeta 1: Teléfonos -->
      <div class="bg-white p-10 rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 flex flex-col items-center text-center animate-on-scroll transform hover:-translate-y-2">
        <div class="w-16 h-16 icon-chip rounded-full flex items-center justify-center mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-zaga-navy mb-4">{t('contact.call_us')}</h3>
        <div class="flex flex-col space-y-3">
          <div class="flex items-center justify-center gap-2">
            <a href="tel:+528331073278" class="text-lg text-gray-600 hover:text-zaga-blue font-medium transition-colors">(833) 107-32-78</a>
            <a
              href="https://wa.me/528331073278?text=Hola%2C%20me%20gustar%C3%ADa%20m%C3%A1s%20informaci%C3%B3n."
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Contactar por WhatsApp"
              class="text-[#25d366] hover:opacity-75 transition-opacity"
            >
              <svg class="w-5 h-5" viewBox="0 0 32 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M16.004 2.667c-7.363 0-13.333 5.97-13.333 13.333 0 2.353.615 4.647 1.784 6.667L2.667 29.333l6.822-1.76a13.27 13.27 0 006.515 1.76h.006c7.362 0 13.333-5.97 13.333-13.333 0-3.56-1.387-6.907-3.906-9.427a13.24 13.24 0 00-9.433-3.906zm0 24.4h-.005a11.02 11.02 0 01-5.62-1.539l-.403-.24-4.05 1.046 1.082-3.948-.263-.405a11.02 11.02 0 01-1.7-5.881c0-6.101 4.965-11.066 11.064-11.066a11 11 0 017.826 3.243 10.98 10.98 0 013.238 7.83c0 6.101-4.966 11.06-11.069 11.06zm6.066-8.288c-.332-.166-1.965-.97-2.27-1.081-.305-.111-.527-.166-.749.166s-.86 1.081-1.054 1.303-.388.25-.72.083c-.332-.166-1.402-.517-2.67-1.649-.987-.881-1.654-1.968-1.848-2.3s-.021-.512.145-.677c.149-.148.332-.388.498-.582.166-.194.221-.333.332-.555.111-.222.055-.416-.028-.582-.083-.166-.749-1.804-1.026-2.472-.27-.65-.545-.562-.749-.572l-.638-.011c-.222 0-.582.083-.887.416s-1.165 1.138-1.165 2.777 1.192 3.222 1.358 3.444c.166.222 2.347 3.584 5.687 5.026.794.343 1.414.548 1.897.702.797.254 1.522.218 2.096.132.64-.096 1.965-.803 2.242-1.579.277-.777.277-1.443.194-1.58-.083-.138-.305-.222-.638-.388z"/>
              </svg>
            </a>
          </div>
          <a href="tel:+528333629238" class="text-lg text-gray-600 hover:text-zaga-blue font-medium transition-colors">(833) 362-92-38</a>
        </div>
      </div>

      <!-- Tarjeta 2: Correos -->
      <div class="bg-white p-10 rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300 flex flex-col items-center text-center animate-on-scroll transform hover:-translate-y-2" style="transition-delay: 150ms;">
        <div class="w-16 h-16 icon-chip rounded-full flex items-center justify-center mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-zaga-navy mb-4">{t('contact.email_us')}</h3>
        <div class="flex flex-col space-y-3">
          <a href="mailto:distribuciones.zaga25@gmail.com" class="text-lg text-gray-600 hover:text-zaga-blue font-medium transition-colors break-all">distribuciones.zaga25@gmail.com</a>
          <a href="mailto:asistente.zaga25@gmail.com" class="text-lg text-gray-600 hover:text-zaga-blue font-medium transition-colors break-all">asistente.zaga25@gmail.com</a>
        </div>
      </div>

    </div>
  </section>
</Layout>
