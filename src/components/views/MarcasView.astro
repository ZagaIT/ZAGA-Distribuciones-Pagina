---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const catalogCategories = [
  {
    titleKey: "brands.cat.title.conductores",
    descKey: "brands.cat.conductores",
    brands: ['CONDUMEX', 'ARGOS', 'VIAKON', 'Indiana Wire & Cable', 'General Cable', 'ondulac', 'KOBREX']
  },
  {
    titleKey: "brands.cat.title.tuberia",
    descKey: "brands.cat.tuberia",
    brands: ['Crouse-Hinds by EATON', 'KILLARK', 'RAWELT', 'Appleton', 'CONDUCCASA', 'Ternium', 'Hylsa', 'INDALUM', 'Thomas & Betts']
  },
  {
    titleKey: "brands.cat.title.control",
    descKey: "brands.cat.control",
    brands: ['SQUARE D', 'SIEMENS', 'ABB', 'OMRON', 'Allen-Bradley', 'MOELLER', 'BALLUFF', 'ARROW HART', 'LEVITON', 'bticino']
  },
  {
    titleKey: "brands.cat.title.iluminacion",
    descKey: "brands.cat.iluminacion",
    brands: ['PHILCO-SLP-BRILLA-MAX', 'tecnolite', 'PHILIPS Lighting', 'Dimas Lighting', 'MAGG', 'LAITING']
  },
  {
    titleKey: "brands.cat.title.proteccion",
    descKey: "brands.cat.proteccion",
    brands: ['TOTAL GROUND', 'AMESA', 'ENERGAIN', 'TECNOLED PLUS']
  },
  {
    titleKey: "brands.cat.title.ferreteria",
    descKey: "brands.cat.ferreteria",
    brands: ['TRUPER', 'VOLTECK', 'PRETUL', 'FOSET', 'FIERO', 'Klintek', 'HERMEX']
  },
  {
    titleKey: "brands.cat.title.construccion",
    descKey: "brands.cat.construccion",
    brands: ['Holcim', 'HELVEX', 'RUGO', 'APASCO', 'LAMOSA', 'CATO', 'Fester', 'CREST', 'cemix', 'Berel', 'Sayer', 'Comex', 'BEHR']
  },
  {
    titleKey: "brands.cat.title.varios",
    descKey: "brands.cat.varios",
    brands: ['3M']
  }
];

const logos = import.meta.glob<{ default: ImageMetadata }>('/src/assets/marcas/*.{png,jpg,jpeg,svg,webp}', { eager: true });

const normalizeBrandName = (name: string) => name.toLowerCase().replace(/[^a-z0-9]/g, '');

const getBrandLogo = (brandName: string): ImageMetadata | null => {
  const normalizedMatch = normalizeBrandName(brandName);
  for (const path in logos) {
    const filename = path.split('/').pop()?.split('.')[0] || '';
    if (normalizeBrandName(filename) === normalizedMatch) {
      return logos[path].default;
    }
  }
  return null;
};

const roboCobreImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/robo-cobre.{jpg,jpeg,png,webp}', { eager: true });
const roboCobreImage = (Object.values(roboCobreImages)[0] as { default: ImageMetadata } | undefined)?.default ?? null;

// Catálogo de categorías de Soldexel
const soldexelCategorias = [
  { titulo: "Áreas Peligrosas Clasificadas",    url: "https://soldexel.com/categoria-producto/areas-peligrosas-clasificadas/",       imgKey: "areas_peligrosas"  },
  { titulo: "Luminarias para Áreas Clasificadas", url: "https://soldexel.com/categoria-producto/iluminacion-areas-clasificadas/",    imgKey: "luminarias"        },
  { titulo: "Áreas de Alto Desempeño",           url: "https://soldexel.com/categoria-producto/areas-de-alto-desempeno-intemperie/", imgKey: "alto_desempeno"    },
  { titulo: "Accesorios de Conexión",            url: "https://soldexel.com/categoria-producto/accesorios-de-conexion/",             imgKey: "accesorios"        },
  { titulo: "Sistemas de Puesta a Tierra",       url: "https://soldexel.com/categoria-producto/sistemas-de-puesta-a-tierra/",        imgKey: "puesta_tierra"     },
  { titulo: "Protección Contra Rayos",           url: "https://soldexel.com/categoria-producto/apantallamiento/",                   imgKey: "proteccion_rayos"  },
];

const categoriasImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/categorias/*.{png,jpg,jpeg,webp}', { eager: true });

const imgKeyToFile: Record<string, string> = {
  areas_peligrosas:  'AreasPeligrosasClasificadas',
  luminarias:        'LuminariasparaAreasClasificadas',
  alto_desempeno:    'AreasdeAltoDesempeno',
  accesorios:        'AccesoriosDeConexion',
  puesta_tierra:     'SistemasDePuestasATierra',
  proteccion_rayos:  'ProteccionContraRayos',
};

const getCategoriaImage = (imgKey: string): ImageMetadata | null => {
  const filename = imgKeyToFile[imgKey];
  if (!filename) return null;
  for (const path in categoriasImages) {
    if (path.includes(filename)) return categoriasImages[path].default;
  }
  return null;
};

const soldexelLogo   = getBrandLogo('soldexel');
const philcoLogo     = getBrandLogo('PHILCO-SLP-BRILLA-MAX');
const dimasLogo      = getBrandLogo('Dimas Lighting');
const copperclladLogo = getBrandLogo('copperclad');
const alumocladLogo  = getBrandLogo('alumoclad');
const conduccasaLogo = getBrandLogo('CONDUCCASA');
const spartanLogo    = getBrandLogo('logo_spartansmartbox');
---

<Layout lang={lang} title={`ZAGA - ${t('brands.title')}`} description={t('brands.subtitle')}>
  <div class="flex-grow flex flex-col">

    <!-- Hero Header -->
    <section class="bg-zaga-navy py-20 lg:py-32 px-6 flex flex-col items-center justify-center relative overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-[0.03]" style="background-image: radial-gradient(#ffffff 2px, transparent 2px); background-size: 30px 30px;"></div>
      <div class="relative z-10 text-center max-w-4xl animate-on-scroll">
        <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold text-white mb-6 tracking-tight relative inline-block drop-shadow-md">
          {t('brands.title')}
          <span class="absolute -bottom-4 left-1/3 right-1/3 h-1.5 bg-zaga-blue rounded-full"></span>
        </h1>
        <p class="text-xl md:text-2xl text-blue-50 mt-10 font-light max-w-3xl mx-auto text-balance">
          {t('brands.subtitle')}
        </p>
      </div>
    </section>

    <!-- Introducción -->
    <section class="py-16 px-6 bg-gray-50 relative border-b border-gray-200">
      <div class="max-w-5xl mx-auto text-center animate-on-scroll">
        <p class="text-xl md:text-2xl text-zaga-navy leading-relaxed mb-6 font-semibold">
          {t('brands.intro.p1')}
        </p>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-8 max-w-4xl mx-auto">
          {t('brands.intro.p2')}
        </p>
        <p class="text-lg md:text-xl font-bold text-zaga-cyan uppercase tracking-wider">
          {t('brands.intro.p3')}
        </p>
      </div>
    </section>

    <!-- ===== DISTRIBUCIONES OFICIALES ===== -->
    <section class="py-24 px-6 bg-white relative">
      <div class="max-w-7xl mx-auto">

        <div class="text-center mb-16 animate-on-scroll">
          <span class="inline-block bg-zaga-cyan/10 text-zaga-cyan text-xs font-semibold px-4 py-2 rounded-full mb-4 uppercase tracking-widest border border-zaga-cyan/20">
            {t('brands.dist.badge')}
          </span>
          <h2 class="text-3xl lg:text-5xl font-bold text-zaga-navy">{t('brands.dist.title')}</h2>
          <div class="h-1 w-20 bg-zaga-cyan mx-auto mt-6 rounded-full"></div>
          <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">{t('brands.dist.subtitle')}</p>
        </div>

        <!-- Soldexel — Tarjeta Principal -->
        <div class="bg-white rounded-3xl shadow-[0_8px_40px_rgb(0,0,0,0.1)] border border-gray-100 overflow-hidden mb-10 animate-on-scroll border-t-4 border-t-blue-600">
          <div class="grid grid-cols-1 lg:grid-cols-5 gap-0">

            <!-- Panel de Logo -->
            <div class="lg:col-span-2 bg-gray-50 flex items-center justify-center p-10 border-r border-gray-100">
              <a href="https://soldexel.com/" target="_blank" rel="noopener noreferrer" class="block w-full max-w-[300px] mx-auto group">
                {soldexelLogo ? (
                  <Image src={soldexelLogo} alt="Soldexel Logo" class="w-full h-auto object-contain transition-transform duration-300 group-hover:scale-105" />
                ) : (
                  <div class="flex items-center justify-center bg-white rounded-2xl p-8 shadow-sm border border-gray-200 text-2xl font-black text-zaga-navy tracking-widest group-hover:border-zaga-blue transition-colors">
                    SOLDEXEL
                  </div>
                )}
              </a>
            </div>

            <!-- Panel de Contenido -->
            <div class="lg:col-span-3 p-10 flex flex-col justify-between">
              <div>
                <h3 class="text-2xl font-bold text-zaga-navy mb-2">Soldexel</h3>
                <p class="text-gray-600 text-lg leading-relaxed mb-8">{t('brands.soldexel.desc')}</p>

                <!-- Catálogo de Categorías Soldexel — Cuadrícula Circular -->
                <div class="grid grid-cols-3 gap-x-4 gap-y-6 mt-2">
                  {soldexelCategorias.map((cat) => {
                    const img = getCategoriaImage(cat.imgKey);
                    return (
                      <a
                        href={cat.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex flex-col items-center gap-2 text-center"
                      >
                        <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full overflow-hidden border-[3px] border-gray-200 group-hover:border-zaga-blue group-hover:scale-110 transition-all duration-300 shadow-sm group-hover:shadow-lg flex-shrink-0">
                          {img ? (
                            <Image src={img} alt={cat.titulo} class="w-full h-full object-cover" />
                          ) : (
                            <div class="w-full h-full bg-blue-50 flex items-center justify-center">
                              <span class="text-[9px] font-bold text-blue-400 text-center px-1 leading-tight">{cat.titulo}</span>
                            </div>
                          )}
                        </div>
                        <span class="text-[11px] font-semibold text-gray-600 group-hover:text-zaga-blue transition-colors leading-tight">{cat.titulo}</span>
                      </a>
                    );
                  })}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Philco + Dimas Lighting -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <!-- Philco Iluminación -->
          <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-[0_8px_30px_rgb(0,0,0,0.08)] border border-gray-100 animate-on-scroll border-t-4 border-t-amber-400 flex flex-col">
            <div class="flex-1">
              <div class="aspect-video bg-gray-50 rounded-2xl flex items-center justify-center p-6 mb-6 shadow-inner">
                {philcoLogo ? (
                  <Image src={philcoLogo} alt="PHILCO Iluminación Logo" class="w-full h-full object-contain" />
                ) : (
                  <span class="font-black text-2xl text-gray-400 tracking-widest">PHILCO</span>
                )}
              </div>
              <h3 class="text-xl font-bold text-zaga-navy mb-2">PHILCO Iluminación</h3>
              <p class="text-gray-600 leading-relaxed">{t('brands.philco.desc')}</p>
            </div>
          </div>

          <!-- Dimas Lighting -->
          <div class="bg-white rounded-3xl p-8 lg:p-10 shadow-[0_8px_30px_rgb(0,0,0,0.08)] border border-gray-100 animate-on-scroll border-t-4 border-t-sky-500 flex flex-col" style="transition-delay: 100ms;">
            <div class="flex-1">
              <div class="aspect-video bg-gray-50 rounded-2xl flex items-center justify-center p-6 mb-6 shadow-inner">
                {dimasLogo ? (
                  <Image src={dimasLogo} alt="Dimas Lighting Logo" class="w-full h-full object-contain" />
                ) : (
                  <span class="font-black text-2xl text-gray-400 tracking-widest">DIMAS LIGHTING</span>
                )}
              </div>
              <h3 class="text-xl font-bold text-zaga-navy mb-2">Dimas Lighting</h3>
              <p class="text-gray-600 leading-relaxed">{t('brands.dimas.desc')}</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== REPRESENTACIONES OFICIALES ===== -->
    <section class="py-24 px-6 bg-gradient-to-b from-slate-50 to-slate-100 relative">
      <div class="max-w-7xl mx-auto">

        <div class="text-center mb-16 animate-on-scroll">
          <span class="inline-block bg-zaga-navy/10 text-zaga-navy text-xs font-semibold px-4 py-2 rounded-full mb-4 uppercase tracking-widest border border-zaga-navy/20">
            {t('brands.rep.badge')}
          </span>
          <h2 class="text-3xl lg:text-5xl font-bold text-zaga-navy">{t('brands.rep.title')}</h2>
          <div class="h-1 w-20 bg-zaga-cyan mx-auto mt-6 rounded-full"></div>
          <p class="mt-6 text-lg text-gray-600 max-w-2xl mx-auto">{t('brands.rep.subtitle')}</p>
        </div>

        <!-- ---- Fábrica 1: Cable Antirrobo ---- -->
        <div class="bg-white rounded-3xl shadow-[0_8px_40px_rgb(0,0,0,0.1)] border border-gray-100 overflow-hidden mb-10 animate-on-scroll">

          <!-- Header de Fábrica -->
          <div class="bg-zaga-navy px-8 py-5 flex items-center gap-5">
            <div class="w-10 h-10 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0 font-bold text-white text-lg">1</div>
            <div>
              <span class="text-white/50 text-xs uppercase tracking-widest">{t('brands.factory.label')}</span>
              <h3 class="text-white text-xl font-bold">{t('brands.cableantirobo.section')}</h3>
            </div>
          </div>

          <div class="p-8 lg:p-12">

            <!-- Concepto CCS -->
            <div class="bg-red-50 border border-red-200 rounded-2xl p-6 mb-10 flex items-start gap-4">
              <div class="w-10 h-10 text-red-600 flex-shrink-0 mt-0.5">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              </div>
              <div>
                <p class="font-bold text-red-900 text-lg mb-1">{t('brands.cableantirobo.concept')}</p>
                <p class="text-red-800 leading-relaxed">{t('brands.cableantirobo.desc')}</p>
              </div>
            </div>

            <!-- Imagen + Info Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">

              <!-- Imagen: Robo de Cobre -->
              <div class="rounded-2xl overflow-hidden bg-gray-900 aspect-video flex items-center justify-center">
                {roboCobreImage ? (
                  <Image src={roboCobreImage} alt={t('brands.copper.theft.label')} class="w-full h-full object-cover" />
                ) : (
                  <div class="text-center p-8">
                    <div class="w-16 h-16 text-gray-600 mx-auto mb-4">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"/></svg>
                    </div>
                    <p class="text-gray-500 text-sm font-medium">{t('brands.copper.theft.label')}</p>
                    <p class="text-gray-600 text-xs mt-1">{t('brands.copper.theft.placeholder')}</p>
                  </div>
                )}
              </div>

              <!-- Información CCS + Enlace -->
              <div class="flex flex-col justify-center gap-6">
                <div>
                  <h4 class="text-xl font-bold text-zaga-navy mb-3">{t('brands.copper.theft.label')}</h4>
                  <p class="text-gray-600 leading-relaxed">{t('brands.cableantirobo.copper.info')}</p>
                </div>
                <a
                  href="https://cableantirobo.com/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="self-start inline-flex items-center gap-2 bg-zaga-navy text-white px-6 py-3 rounded-xl font-semibold hover:bg-zaga-blue transition-colors duration-200"
                >
                  cableantirobo.com
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              </div>
            </div>

            <!-- 3 Marcas: Copperclad, Alumoclad, Conduccasa -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

              <!-- Copperclad -->
              <div class="border border-gray-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
                <a href="https://copperclad.com.mx/" target="_blank" rel="noopener noreferrer" class="block bg-gray-50 p-6 flex items-center justify-center aspect-video hover:bg-gray-100 transition-colors">
                  {copperclladLogo ? (
                    <Image src={copperclladLogo} alt="Copperclad Logo" class="w-full h-full object-contain" />
                  ) : (
                    <span class="font-black text-lg text-gray-400 tracking-wider text-center">COPPERCLAD</span>
                  )}
                </a>
                <div class="p-5 flex flex-col flex-1 gap-4">
                  <div>
                    <h4 class="font-bold text-zaga-navy mb-1">Copperclad</h4>
                    <p class="text-sm text-gray-600 leading-relaxed">{t('brands.copperclad.desc')}</p>
                  </div>
                  <div class="mt-auto">
                    <a href="/pdfs/copperclad.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-red-50 hover:bg-red-100 text-red-700 border border-red-200 px-3 py-2 rounded-lg text-sm font-semibold transition-colors duration-200">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                      {t('brands.pdf.view')}
                    </a>
                  </div>
                </div>
              </div>

              <!-- Alumoclad -->
              <div class="border border-gray-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
                <a href="https://alumoclad.com.mx/" target="_blank" rel="noopener noreferrer" class="block bg-gray-50 p-6 flex items-center justify-center aspect-video hover:bg-gray-100 transition-colors">
                  {alumocladLogo ? (
                    <Image src={alumocladLogo} alt="Alumoclad Logo" class="w-full h-full object-contain" />
                  ) : (
                    <span class="font-black text-lg text-gray-400 tracking-wider text-center">ALUMOCLAD</span>
                  )}
                </a>
                <div class="p-5 flex flex-col flex-1 gap-4">
                  <div>
                    <h4 class="font-bold text-zaga-navy mb-1">Alumoclad</h4>
                    <p class="text-sm text-gray-600 leading-relaxed">{t('brands.alumoclad.desc')}</p>
                  </div>
                  <div class="mt-auto">
                    <a href="/pdfs/alumoclad.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-red-50 hover:bg-red-100 text-red-700 border border-red-200 px-3 py-2 rounded-lg text-sm font-semibold transition-colors duration-200">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                      {t('brands.pdf.view')}
                    </a>
                  </div>
                </div>
              </div>

              <!-- Conduccasa -->
              <div class="border border-gray-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
                <a href="https://conduccasa.com/" target="_blank" rel="noopener noreferrer" class="block bg-gray-50 p-6 flex items-center justify-center aspect-video hover:bg-gray-100 transition-colors">
                  {conduccasaLogo ? (
                    <Image src={conduccasaLogo} alt="Conduccasa Logo" class="w-full h-full object-contain" />
                  ) : (
                    <span class="font-black text-lg text-gray-400 tracking-wider text-center">CONDUCCASA</span>
                  )}
                </a>
                <div class="p-5 flex flex-col flex-1 gap-4">
                  <div>
                    <h4 class="font-bold text-zaga-navy mb-1">Conduccasa</h4>
                    <p class="text-sm text-gray-600 leading-relaxed">{t('brands.conduccasa.ccs.desc')}</p>
                  </div>
                  <div class="mt-auto">
                    <a href="/pdfs/conduccasa.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-red-50 hover:bg-red-100 text-red-700 border border-red-200 px-3 py-2 rounded-lg text-sm font-semibold transition-colors duration-200">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                      {t('brands.pdf.view')}
                    </a>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- ---- Fábrica 2: Spartan Smart Box ---- -->
        <div class="bg-white rounded-3xl shadow-[0_8px_40px_rgb(0,0,0,0.1)] border border-gray-100 overflow-hidden animate-on-scroll">

          <!-- Header de Fábrica -->
          <div class="bg-zaga-navy px-8 py-5 flex items-center gap-5">
            <div class="w-10 h-10 bg-zaga-cyan rounded-full flex items-center justify-center flex-shrink-0 font-bold text-zaga-navy text-lg">2</div>
            <div>
              <span class="text-white/50 text-xs uppercase tracking-widest">{t('brands.factory.label')}</span>
              <h3 class="text-white text-xl font-bold">{t('brands.spartan.title')}</h3>
            </div>
          </div>

          <div class="p-8 lg:p-12 grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">

            <!-- Logo -->
            <div class="lg:col-span-2 flex items-center justify-center">
              <div class="bg-slate-50 rounded-2xl p-10 border border-slate-200 w-full max-w-sm flex items-center justify-center aspect-video">
                {spartanLogo ? (
                  <Image src={spartanLogo} alt="Spartan Smart Box Logo" class="w-full h-full object-contain" />
                ) : (
                  <span class="font-black text-xl text-gray-400 tracking-wider text-center leading-relaxed">SPARTAN<br/>SMART BOX</span>
                )}
              </div>
            </div>

            <!-- Contenido -->
            <div class="lg:col-span-3 flex flex-col gap-6">

              <!-- Slogan -->
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 text-slate-600 flex-shrink-0">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 00-1.032 0 11.209 11.209 0 01-7.877 3.08.75.75 0 00-.722.515A12.74 12.74 0 002.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 00.374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 00-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08z" clip-rule="evenodd"/></svg>
                </div>
                <div>
                  <span class="text-xs font-semibold text-slate-400 uppercase tracking-widest block mb-0.5">Especialistas en</span>
                  <h4 class="text-xl font-black text-slate-800 leading-tight">{t('brands.spartan.slogan')}</h4>
                </div>
              </div>

              <!-- Descripción principal -->
              <p class="text-gray-600 text-base leading-relaxed">{t('brands.spartan.main.desc')}</p>

              <!-- Clientes principales -->
              <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">{t('brands.spartan.clients.intro')}</p>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">

                  <!-- Bancos -->
                  <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex flex-col gap-2">
                    <div class="w-7 h-7 text-slate-500">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/></svg>
                    </div>
                    <h5 class="font-bold text-slate-800 text-sm">Bancos</h5>
                    <p class="text-xs text-gray-500 leading-relaxed">{t('brands.spartan.client.bancos')}</p>
                  </div>

                  <!-- Hoteles -->
                  <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex flex-col gap-2">
                    <div class="w-7 h-7 text-slate-500">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>
                    </div>
                    <h5 class="font-bold text-slate-800 text-sm">Hoteles</h5>
                    <p class="text-xs text-gray-500 leading-relaxed">{t('brands.spartan.client.hoteles')}</p>
                  </div>

                  <!-- Constructoras -->
                  <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 flex flex-col gap-2">
                    <div class="w-7 h-7 text-slate-500">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                    </div>
                    <h5 class="font-bold text-slate-800 text-sm">Constructoras</h5>
                    <p class="text-xs text-gray-500 leading-relaxed">{t('brands.spartan.client.constructoras')}</p>
                  </div>

                </div>
              </div>

              <!-- Cobertura Nacional -->
              <div class="flex items-center gap-3 bg-zaga-navy/5 border border-zaga-navy/10 rounded-xl px-5 py-3">
                <div class="w-5 h-5 text-zaga-cyan flex-shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                </div>
                <p class="text-sm font-semibold text-zaga-navy">{t('brands.spartan.coverage')}</p>
              </div>

            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ===== CATÁLOGO GENERAL DE MARCAS ===== -->
    <section class="pb-32 pt-24 px-6 bg-white relative">
      <div class="max-w-7xl mx-auto">

        <div class="mb-12 animate-on-scroll text-center">
          <h2 class="text-3xl lg:text-4xl font-bold text-zaga-navy flex items-center justify-center gap-4">
            <svg class="w-8 h-8 text-zaga-cyan" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.5 4A1.5 1.5 0 001 5.5V14a2 2 0 002 2h14a2 2 0 002-2V5.5A1.5 1.5 0 0017.5 4h-15zM9 8a1 1 0 011-1h6a1 1 0 110 2h-6a1 1 0 01-1-1zm-4.707 3.707a1 1 0 00-1.414-1.414l-1.5 1.5a1 1 0 000 1.414l1.5 1.5a1 1 0 001.414-1.414L3.414 12l.879-.879zM9 12a1 1 0 011-1h6a1 1 0 110 2h-6a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
            {t('brands.catalog')}
          </h2>
          <p class="mt-4 text-gray-600 text-lg max-w-3xl mx-auto">{t('brands.catalog.intro')}</p>
        </div>

        <div class="space-y-16">
          {catalogCategories.map((category) => (
            <div class="animate-on-scroll">
              <h3 class="text-2xl font-bold text-zaga-navy mb-4 border-b-2 border-zaga-cyan/30 pb-3 flex items-center gap-3">
                <span class="w-2 h-6 bg-zaga-cyan rounded-full"></span>
                {t(category.titleKey as any)}
              </h3>
              <p class="text-gray-600 text-lg leading-relaxed mb-8 max-w-4xl">
                {t(category.descKey as any)}
              </p>
              <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
                {category.brands.map((brand) => {
                  const logo = getBrandLogo(brand);
                  return (
                    <div class="aspect-square bg-gray-50 border border-gray-200/60 rounded-xl shadow-sm hover:shadow-lg flex items-center justify-center p-4 transition-all duration-300 hover:-translate-y-1 hover:border-zaga-blue group">
                      {logo ? (
                        <Image src={logo} alt={`${brand} Logo`} class="w-full h-full object-contain opacity-90 group-hover:opacity-100 transition-opacity duration-300" />
                      ) : (
                        <span class="font-bold text-gray-400 text-center tracking-wider text-sm sm:text-base group-hover:text-zaga-navy transition-colors">{brand}</span>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- Mensaje Final -->
    <section class="py-20 px-6 bg-zaga-navy relative overflow-hidden">
      <div class="absolute inset-0 z-0 opacity-[0.03]" style="background-image: radial-gradient(#ffffff 2px, transparent 2px); background-size: 30px 30px;"></div>
      <div class="relative z-10 max-w-4xl mx-auto text-center animate-on-scroll">
        <h3 class="text-2xl md:text-4xl font-bold text-white mb-6 leading-tight">
          {t('brands.outro.p1')}
        </h3>
        <p class="text-xl md:text-2xl text-blue-50/80 font-light max-w-3xl mx-auto">
          {t('brands.outro.p2')}
        </p>
      </div>
    </section>

  </div>
</Layout>
