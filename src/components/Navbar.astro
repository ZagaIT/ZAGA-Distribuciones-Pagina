---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages } from '../i18n/ui';
import { Image } from 'astro:assets';
import logoZaga from '../assets/logoZaga.png';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'en' ? '/en' : '';

const currentPath = Astro.url.pathname.replace(/^\/en/, '') || '/';
const pathEs = currentPath;
const pathEn = `/en${currentPath === '/' ? '' : currentPath}`;
---

<nav class="sticky top-0 z-50 bg-zaga-navy/85 backdrop-blur-md border-b border-white/10 transition-all duration-300 text-white p-4">
  <div class="container mx-auto flex justify-between items-center">
    
    <!-- Header Logo "Insignia" -->
    <a href={`${basePath}/`} class="flex items-center gap-3 md:gap-4 group">
      <div class="bg-white p-2 md:p-2.5 rounded-2xl shadow-xl inline-block group-hover:-translate-y-1 transition-transform duration-300">
        <Image alt="ZAGA Distribuciones Logo" class="w-10 h-10 md:w-12 md:h-12 object-contain" src={logoZaga}/>
      </div>
      <span class="text-2xl md:text-3xl font-bold tracking-widest uppercase group-hover:text-zaga-cyan transition-colors mt-2 md:mt-0">ZAGA</span>
    </a>

    <!-- Hamburguesa Mobile -->
    <button id="menu-toggle" class="lg:hidden flex items-center text-white focus:outline-none p-2" aria-label="Abrir menú">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <!-- Navegación -->
    <div id="nav-menu" class="hidden lg:flex flex-col lg:flex-row absolute lg:static top-full left-0 w-full lg:w-auto bg-zaga-navy/95 lg:bg-transparent backdrop-blur-lg lg:backdrop-blur-none p-6 lg:p-0 gap-6 lg:gap-8 shadow-2xl lg:shadow-none border-t border-white/10 lg:border-none transition-all">
      <a href={`${basePath}/nosotros`} class="hover:text-zaga-cyan font-medium transition-colors flex items-center text-lg lg:text-base">{t('nav.about')}</a>
      <a href={`${basePath}/servicios`} class="hover:text-zaga-cyan font-medium transition-colors flex items-center text-lg lg:text-base">{t('nav.services')}</a>
      <a href={`${basePath}/marcas`} class="hover:text-zaga-cyan font-medium transition-colors flex items-center text-lg lg:text-base">{t('nav.brands')}</a>
      <a href={`${basePath}/contacto`} class="lg:ml-2 bg-zaga-blue px-6 py-3 lg:py-2.5 rounded-xl lg:rounded-lg hover:bg-zaga-cyan hover:text-zaga-navy font-bold transition-transform hover:-translate-y-0.5 text-center shadow-lg text-lg lg:text-base">{t('nav.contact')}</a>

      <!-- Selector de Idiomas -->
      <div class="relative pt-4 lg:pt-0 border-t border-white/10 lg:border-none lg:ml-4 flex items-center">
        <button id="lang-menu-btn" class="flex items-center justify-between w-full lg:w-auto gap-3 bg-white/10 border border-white/20 rounded-xl lg:rounded-lg py-3 px-5 lg:py-2.5 lg:px-4 text-white focus:outline-none hover:border-zaga-cyan hover:bg-white/20 transition-all">
          <span class="font-medium tracking-wide">{lang === 'es' ? '🇲🇽 ES' : '🇺🇸 EN'}</span>
          <svg class="w-4 h-4 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        
        <div id="lang-dropdown" class="absolute hidden top-full mt-3 w-full lg:w-44 bg-white text-gray-800 rounded-xl shadow-2xl overflow-hidden z-20 border border-gray-100 flex-col right-0 transform origin-top transition-all">
          <a href={pathEs} class="px-5 py-3.5 hover:bg-blue-50 flex items-center gap-3 transition-colors border-b border-gray-100 font-medium">
            <span class="text-xl">🇲🇽</span> Español
          </a>
          <a href={pathEn} class="px-5 py-3.5 hover:bg-blue-50 flex items-center gap-3 transition-colors font-medium">
            <span class="text-xl">🇺🇸</span> English
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  const toggleBtn = document.getElementById('menu-toggle');
  const menu = document.getElementById('nav-menu');
  const langBtn = document.getElementById('lang-menu-btn');
  const langDropdown = document.getElementById('lang-dropdown');

  if (toggleBtn && menu) {
    toggleBtn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      menu.classList.toggle('flex');
    });
  }

  if (langBtn && langDropdown) {
    langBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown.classList.toggle('hidden');
      langDropdown.classList.toggle('flex');
    });
    
    document.addEventListener('click', () => {
      if (!langDropdown.classList.contains('hidden')) {
        langDropdown.classList.add('hidden');
        langDropdown.classList.remove('flex');
      }
    });
  }
</script>
